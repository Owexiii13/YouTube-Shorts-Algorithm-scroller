{
  "manifest_version": 3,
  "name": "YouTube-Shorts-Algorithm-Scroller",
  "version": "2.0.0",
  "description": "Autoscroll YouTube Shorts for you because doom scrolling is too tiring.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["*"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
